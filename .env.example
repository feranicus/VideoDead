# ---- Copy to .env and fill in. NEVER commit .env. ----

# Public domain Caddy will obtain HTTPS for. Use "localhost" for local dev.
DOMAIN=localhost

# Admin email (used for Let's Encrypt + first-run wizard reference).
ADMIN_EMAIL=you@example.com

# Random secret for signing sessions. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string

# Redis connection (internal docker network).
REDIS_URL=redis://redis:6379/0

# Where finished files are stored inside the worker container.
DOWNLOAD_DIR=/downloads

# Auto-delete finished files after this many hours.
FILE_TTL_HOURS=6

# Hard caps to protect the server.
MAX_FILESIZE_MB=2048
MAX_DURATION_MIN=240
MAX_CONCURRENT_DOWNLOADS=2
# Max seconds a single download may run before it is cancelled (big files need more).
JOB_TIMEOUT_SECONDS=3600

# Per-IP rate limits (requests per minute).
RATE_LIMIT_LOGIN=10
RATE_LIMIT_SUBMIT=20

# ---- Optional YouTube auto-cookies (the "youtube" compose profile) ----
# Basic-auth for the browser login UI (reached only via SSH tunnel).
BROWSER_USER=admin
BROWSER_PASSWORD=change-me-too
# How often (seconds) to re-export cookies from the logged-in browser.
EXPORT_INTERVAL=1800

# ---- Optional observability (the "observe" compose profile) ----
# Login for the Grafana dashboard at https://<domain>/observe
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-strong

# ---- Audit / security ----
# Extra hostnames to FLAG as suspicious (comma-separated). Adds to the built-in
# piracy/torrent watchlist. Flag-and-alert only (not a block). Optional.
SUSPICIOUS_DOMAINS=
