# Automatic HTTPS + security headers. Serves the React SPA and proxies /api.
{
	email {$ADMIN_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# HSTS + server hiding apply site-wide (safe for every route).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	# API (JSON + WebSocket) to the FastAPI container.
	handle /api/* {
		reverse_proxy api:8000
	}

	# Observability dashboard (Grafana) — only reachable when the "observe"
	# profile is running. Grafana has its own login and ships its own headers,
	# so we set NO strict CSP/frame rules here (they would break its UI).
	handle /observe* {
		reverse_proxy grafana:3000
	}

	# Everything else is the static SPA. The strict CSP lives HERE only, so it
	# never touches Grafana. Deep links fall back to index.html.
	handle {
		header {
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "strict-origin-when-cross-origin"
			Permissions-Policy "geolocation=(), microphone=(), camera=()"
			Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		}
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
