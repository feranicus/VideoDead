# Automatic HTTPS + security headers. Serves the React SPA and proxies /api.
{
	email {$ADMIN_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# Security headers (CSA SAS network/platform; OWASP).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	# API (JSON + WebSocket) to the FastAPI container.
	handle /api/* {
		reverse_proxy api:8000
	}

	# Observability dashboard (Grafana) — only reachable when the "observe"
	# profile is running. Grafana has its own login. Relax the strict CSP/frame
	# rules here so the dashboard app works.
	handle /observe* {
		header -Content-Security-Policy
		header -X-Frame-Options
		reverse_proxy grafana:3000
	}

	# Everything else is the static SPA; deep links fall back to index.html.
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
